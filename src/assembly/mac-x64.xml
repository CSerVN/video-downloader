<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1 https://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>Mac-Intel</id>
    <formats><format>tar.gz</format></formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <files>
        <file>
            <source>${project.build.directory}/${project.build.finalName}-jar-with-dependencies.jar</source>
            <outputDirectory>/</outputDirectory>
            <destName>VideoDownloader.jar</destName>
        </file>
    </files>
    <fileSets>
        <fileSet>
            <directory>${project.basedir}/tools</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>*-macos</include>
                <include>run.sh</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/tools/jre-mac-x64</directory>
            <outputDirectory>/jre-mac-x64</outputDirectory>
            <fileMode>0755</fileMode>
        </fileSet>
    </fileSets>
</assembly>